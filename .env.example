# ─── App ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://investment-lens.vercel.app
NEXT_PUBLIC_VERCEL_ENV=development

# ─── Database (Neon / Supabase / PostgreSQL) ────────────────────────────────
DATABASE_URL=postgres://user:password@host:port/db
DATABASE_AUTH_TOKEN=

# ─── Auth (Auth.js / NextAuth.js) ───────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=your_nextauth_secret_32_chars_min
AUTH_GOOGLE_ID=your_google_oauth_client_id
AUTH_GOOGLE_SECRET=your_google_oauth_client_secret

# ─── LLM Provider ───────────────────────────────────────────────────────────
# Select provider: openai | openrouter | gemini  (default: openai)
LLM_PROVIDER=openai

# ─── OpenAI ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o

# ─── OpenRouter ───────────────────────────────────────────────────────────
# Get from: https://openrouter.ai/keys
# Model list: https://openrouter.ai/models
OPENROUTER_API_KEY=sk-or-your-openrouter-key
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# ─── Google Gemini ─────────────────────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
# Model options: gemini-2.0-flash | gemini-2.0-flash-lite | gemini-2.5-pro-preview-03-25
GOOGLE_GENERATIVE_AI_API_KEY=your-google-ai-studio-key
GEMINI_MODEL=gemini-2.0-flash

# ─── Upstash Redis (Rate Limiting) ──────────────────────────────────────────
# Used by @upstash/ratelimit for production-grade rate limiting
# Get from: https://console.upstash.com
KV_URL=redis://your-upstash-redis-url
KV_REST_API_URL=https://your-upstash-redis-rest-url
KV_REST_API_TOKEN=your-upstash-redis-token

# ─── Analytics ──────────────────────────────────────────────────────────────
# PostHog – used by skills/alphaear-deepear-lite for telemetry
# Get from: https://us.posthog.com/project/settings
POSTHOG_API_KEY=

# ─── Notes ──────────────────────────────────────────────────────────────────
# AUTH_SECRET is REQUIRED in all environments. Generate with:
#   openssl rand -base64 32
# Never commit actual secrets to the repository.
# Only one LLM provider key is required (matching LLM_PROVIDER value).
